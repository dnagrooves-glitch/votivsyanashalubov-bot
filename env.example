# Токен бота — @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token

# Replicate — replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token

# D-ID — studio.d-id.com → Settings → API
# Формат: base64(email:api_key) — см. README
DID_API_KEY=your_did_api_key_base64

# Прямая ссылка на mp3 фрагмент припева (~8 секунд)
# Загрузить на: Cloudflare R2 / S3 / Яндекс Диск (прямая ссылка)
CHORUS_AUDIO_URL=https://your-storage.com/veeka_chorus.mp3

# Ссылка на трек
TRACK_URL=https://music.yandex.ru/track/veeka
